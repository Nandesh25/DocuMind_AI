# Application
APP_NAME=DocuMind AI
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Security
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_MINUTES=10080
ALGORITHM=HS256

# CORS (comma-separated)
BACKEND_CORS_ORIGINS=http://localhost:4200

# Database
POSTGRES_USER=documind
POSTGRES_PASSWORD=documind
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=documind

# Storage
STORAGE_DIR=./storage
MAX_UPLOAD_SIZE_MB=25

# AI
OLLAMA_BASE_URL=http://localhost:11434
# Chat model served by Ollama. Recommended free/open models:
#   qwen2.5:3b  (default, fast)   qwen2.5:7b   gemma2:2b   gemma2:9b
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_TEMPERATURE=0.2
OLLAMA_NUM_CTX=8192
OLLAMA_MAX_TOKENS=1024

# LLM provider: "ollama" (self-hosted) or "openai" (any OpenAI-compatible API,
# e.g. Groq / OpenRouter — useful for free hosting where Ollama can't run).
LLM_PROVIDER=ollama
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384
EMBEDDING_BATCH_SIZE=32
# Vector store: leave CHROMA_HOST blank for embedded mode, or set it to the
# ChromaDB service host (e.g. "chromadb") to use the HTTP server.
CHROMA_DIR=./chroma
CHROMA_HOST=
CHROMA_PORT=8000
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
RETRIEVAL_TOP_K=5

# Ops: create tables on startup (dev/docker). Use Alembic in production.
AUTO_CREATE_TABLES=false
