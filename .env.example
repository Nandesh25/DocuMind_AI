# Root environment for docker compose (copy to .env and edit).
# These override the defaults baked into docker-compose.yml.

# Security — CHANGE THIS to a long random string in any real deployment.
SECRET_KEY=change-me-to-a-long-random-string

# PostgreSQL credentials
POSTGRES_USER=documind
POSTGRES_PASSWORD=documind
POSTGRES_DB=documind

# LLM model served by Ollama (qwen2.5:3b default; gemma2:2b also works)
OLLAMA_MODEL=qwen2.5:3b

# Comma-separated allowed frontend origins for CORS
BACKEND_CORS_ORIGINS=http://localhost:8080
